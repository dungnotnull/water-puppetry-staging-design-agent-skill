# water-puppetry-staging-design environment variables
# Copy to .env and fill in values

# Logging
WPSD_LOG_LEVEL=INFO
WPSD_LOG_FILE=logs/knowledge_update.log
WPSD_DRY_RUN=false
WPSD_NEWS_ONLY=false

# API keys (if required by future sources)
# ARXIV_API_KEY=
# SEMANTIC_SCHOLAR_API_KEY=

# RSS feeds (JSON array)
# WPSD_RSS_FEEDS='["https://example.com/feed.xml"]'

# Feature flags (override config/feature_flags.yaml; values: true|false)
# WPSD_FLAG_ENABLE_ROUTER=true
# WPSD_FLAG_ENABLE_HOOKS=true
# WPSD_FLAG_ENABLE_SCHEMA_VALIDATION=true
# WPSD_FLAG_ENABLE_TOKEN_BUDGET=true
# WPSD_FLAG_ENABLE_LIVE_FETCH=false
# WPSD_FLAG_MAX_GATE_RETRIES=2
