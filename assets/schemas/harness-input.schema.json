{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://water-puppetry.local/schemas/harness-input.schema.json",
  "title": "HarnessInput",
  "type": "object",
  "required": [
    "object"
  ],
  "properties": {
    "object": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string"
    },
    "timeframe": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "venue": {
      "type": "object"
    },
    "equipment": {
      "type": "object"
    },
    "lighting": {
      "type": "object"
    },
    "safety": {
      "type": "object"
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_strength": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_chain": {
      "type": "array"
    },
    "remediation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
